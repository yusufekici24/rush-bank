# Unity YAML dosyaları için akıllı birleştirme (UnityYAMLMerge kullanılabilir)
*.unity text merge=unityyamlmerge eol=lf
*.prefab text merge=unityyamlmerge eol=lf
*.asset text merge=unityyamlmerge eol=lf
*.meta text merge=unityyamlmerge eol=lf

# Kaynak dosyalar
*.cs text diff=csharp eol=lf
*.shader text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary dosyalar (diff alınmaz)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.tga binary
*.tif binary
*.fbx binary
*.obj binary
*.blend binary
*.mp3 binary
*.wav binary
*.ogg binary
*.ttf binary
*.otf binary
*.dll binary
*.so binary
*.a binary
